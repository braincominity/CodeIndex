{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disableSkillShellExecution": true,
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(dotnet)",
      "Bash(dotnet *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(codex exec --ephemeral *)"
    ],
    "deny": [
      "WebFetch(chatgpt.com)",
      "WebFetch(*chatgpt.com*)",
      "Bash(codex:rescue *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p8)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*.jks)",
      "Read(**/*keystore*)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.pub)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.pub)",
      "Read(**/credentials)",
      "Read(**/credentials*)",
      "Read(**/*credential*)",
      "Read(**/*credentials*)",
      "Read(**/secret)",
      "Read(**/secrets)",
      "Read(**/*secret*)",
      "Read(**/*secrets*)",
      "Read(**/*service-account*.json)",
      "Read(**/*firebase*.json)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/.netrc)",
      "Read(**/NuGet.Config)",
      "Read(**/nuget.config)",
      "Read(**/settings.xml)",
      "Read(**/gradle.properties)",
      "Read(**/local.settings.json)",
      "Read(**/appsettings.*.local.json)",
      "Read(**/appsettings.Production.json)",
      "Read(**/*.kdbx)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.kube/**)",
      "Read(~/.docker/**)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Read(~/Applications)",
      "Read(~/Applications/**)",
      "Read(~/Desktop)",
      "Read(~/Desktop/**)",
      "Read(~/Documents)",
      "Read(~/Documents/**)",
      "Read(~/Downloads)",
      "Read(~/Downloads/**)",
      "Read(~/Library)",
      "Read(~/Library/**)",
      "Read(~/Movies)",
      "Read(~/Movies/**)",
      "Read(~/Music)",
      "Read(~/Music/**)",
      "Read(~/Pictures)",
      "Read(~/Pictures/**)",
      "Read(~/Public)",
      "Read(~/Public/**)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "denyRead": [
        "/private/var/db",
        "/var/db",
        "~/.ssh",
        "~/.ssh/**",
        "~/.gnupg",
        "~/.gnupg/**",
        "~/.aws",
        "~/.aws/**",
        "~/.azure",
        "~/.azure/**",
        "~/.config/gcloud",
        "~/.config/gcloud/**",
        "~/.kube",
        "~/.kube/**",
        "~/.docker",
        "~/.docker/**",
        "~/Applications",
        "~/Applications/**",
        "~/Desktop",
        "~/Desktop/**",
        "~/Documents",
        "~/Documents/**",
        "~/Downloads",
        "~/Downloads/**",
        "~/.git-credentials",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/Library",
        "~/Library/**",
        "~/Movies",
        "~/Movies/**",
        "~/Music",
        "~/Music/**",
        "~/Pictures",
        "~/Pictures/**",
        "~/Public",
        "~/Public/**"
      ],
      "allowRead": [
        ".",
        "/tmp",
        "/private/tmp",
        "~/.nuget/packages",
        "~/.config/gh",
        "~/.config/gh/**"
      ],
      "denyWrite": [
        "/Applications",
        "/Library",
        "/System",
        "/bin",
        "/sbin",
        "/usr",
        "/etc",
        "/private/etc",
        "/var/db",
        "/private/var/db",
        "./.claude/settings.json",
        "./.claude/settings.local.json",
        "./.claude/hooks/bash-guard.py"
      ],
      "allowWrite": [
        ".",
        "/tmp",
        "/private/tmp",
        "~/.nuget/packages",
        "~/.codex",
        "~/.codex/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "api.nuget.org",
        "www.nuget.org",
        "globalcdn.nuget.org",
        "api.openai.com",
        "github.com",
        "api.github.com"
      ],
      "allowLocalBinding": false,
      "allowAllUnixSockets": false
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash-guard.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
