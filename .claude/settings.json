{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disableSkillShellExecution": true,
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Bash(dotnet)",
      "Bash(dotnet *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(codex exec --ephemeral *)"
    ],
    "deny": [
      "WebFetch(chatgpt.com)",
      "WebFetch(*chatgpt.com*)",
      "Bash(codex:rescue *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": true,
    "filesystem": {
      "denyRead": [
        "/private/var/db",
        "/var/db"
      ],
      "allowRead": [
        ".",
        "/tmp",
        "/private/tmp",
        "~/.nuget/packages",
        "~/.config/gh",
        "~/.config/gh/**"
      ],
      "denyWrite": [
        "/Applications",
        "/Library",
        "/System",
        "/bin",
        "/sbin",
        "/usr",
        "/etc",
        "/private/etc",
        "/var/db",
        "/private/var/db",
        "./.claude/settings.json",
        "./.claude/settings.local.json",
        "./.claude/hooks/bash-guard.py"
      ],
      "allowWrite": [
        ".",
        "/tmp",
        "/private/tmp",
        "~/.nuget/packages",
        "~/.codex",
        "~/.codex/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "api.nuget.org",
        "www.nuget.org",
        "globalcdn.nuget.org",
        "api.openai.com",
        "github.com",
        "api.github.com"
      ],
      "allowLocalBinding": false,
      "allowAllUnixSockets": false
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bash-guard.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
