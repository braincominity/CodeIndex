{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Optional. Copy to .claude/settings.local.json or merge into ~/.claude/settings.json. Do not commit settings.local.json. Replace the CodeIndex .git path if your common git dir differs.",
  "env": {
    "GH_NO_UPDATE_NOTIFIER": "1",
    "GH_NO_EXTENSION_UPDATE_NOTIFIER": "1",
    "GH_PROMPT_DISABLED": "1"
  },
  "sandbox": {
    "filesystem": {
      "allowRead": [
        "~/.gitconfig",
        "~/.config/git",
        "~/.config/git/**",
        "~/.config/gh",
        "~/.config/gh/**",
        "~/Projects/mine/CodeIndex/.git",
        "~/Projects/mine/CodeIndex/.git/**"
      ],
      "allowWrite": [
        "~/Projects/mine/CodeIndex/.git",
        "~/Projects/mine/CodeIndex/.git/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "uploads.github.com"
      ]
    }
  }
}
